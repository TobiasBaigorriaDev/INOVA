PORT=3000

# PostgreSQL (Base de datos local)
PG_DATABASE=inova_sql
PG_USER=postgres
PG_PASSWORD=tu_contraseña_aqui
PG_HOST=localhost
PG_PORT=5432

# Cloudinary (Almacenamiento de imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Autenticación y Seguridad
JWT_SECRET=tu_jwt_secret_aqui

# Correos con acceso de administrador (separados por coma, sin espacios)
ADMIN_EMAILS=tu_email@ejemplo.com,otro_email@ejemplo.com

# Mercado Pago (Pasarela de pagos)
MP_ACCESS_TOKEN=tu_access_token_aqui
MP_PUBLIC_KEY=tu_public_key_aqui

# IA Gemini
GEMINI_API_KEY=tu_clave_api_aqui
